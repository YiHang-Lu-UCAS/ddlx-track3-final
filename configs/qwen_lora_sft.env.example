# Copy this file to configs/qwen_lora_sft.env and set the four paths below.
CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
NPROC_PER_NODE=8
MASTER_PORT=29636

MODEL_NAME_OR_PATH=/path/to/models/explanation/qwen2_5_vl_3b_instruct
TRAIN_DATA=/path/to/train_swift.jsonl
VAL_DATA=/path/to/tune_eval_1024_swift.jsonl
OUTPUT_DIR=/path/to/qwen_lora_output

TUNER_TYPE=lora
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
TARGET_MODULES=all-linear
NUM_TRAIN_EPOCHS=1
PER_DEVICE_TRAIN_BATCH_SIZE=1
PER_DEVICE_EVAL_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=4
LEARNING_RATE=5e-5
WARMUP_RATIO=0.03
WEIGHT_DECAY=0.1
LR_SCHEDULER_TYPE=cosine
MAX_LENGTH=4096
MAX_PIXELS=602112
SAVE_STEPS=250
EVAL_STEPS=250
LOGGING_STEPS=10
SAVE_TOTAL_LIMIT=4
DATALOADER_NUM_WORKERS=2
DATASET_NUM_PROC=2
LAZY_TOKENIZE=true
GRADIENT_CHECKPOINTING=true
REPORT_TO=none
BF16=false
FP16=true
TORCH_DTYPE=float16
EVAL_STRATEGY=steps
SAVE_STRATEGY=steps
RESUME_FROM_CHECKPOINT=
